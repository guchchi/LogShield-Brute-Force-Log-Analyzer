# LogShield .gitignore

# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
*.egg-info/
*.egg

# Virtual environment
venv/
env/
.venv/

# IDE / editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Reports generated at runtime (optional - uncomment to exclude)
# reports/incident_report.txt
# reports/incident_report.json
